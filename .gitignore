# ==========================================================================
# Secrets — NEVER commit these
# ==========================================================================
.env
.env.*
!.env.example
*.secret
*.key
*.pem
*.p12
*.pfx
credentials.json
service-account*.json
.claude/.credentials.json
secrets/

# ==========================================================================
# Backup / temp files — scanner flags these on other sites,
# so committing them here would be embarrassing
# ==========================================================================
*.bak
*.old
*.backup
*.swp
*.swo
*.tmp
*.orig
*~
b64_temp.txt

# ==========================================================================
# IDE / editor
# ==========================================================================
.vscode/
.idea/
*.sublime-*
.cursor/

# ==========================================================================
