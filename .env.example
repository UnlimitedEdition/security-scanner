# ==========================================================================
# Web Security Scanner — Environment Variables
# ==========================================================================
# Copy this file to `.env` and fill in actual values.
# NEVER commit `.env` to git. `.gitignore` blocks it.
#
# On HuggingFace Spaces: set these as Space Secrets in Settings → Variables
#   https://huggingface.co/spaces/<user>/<space>/settings
# On Vercel: set these as Environment Variables in Project Settings.
# ==========================================================================


# ──────────────────────────────────────────────────────────────────────────
# Supabase (required for Function 6 — ownership verification + audit log)
# ──────────────────────────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard/project/<your-project>/settings/api
# After creating a project:
#   1. Settings → API → Project URL            -> SUPABASE_URL
#   2. Settings → API → service_role secret    -> SUPABASE_SERVICE_KEY  (BACKEND ONLY!)
#   3. Settings → API → anon public             -> SUPABASE_ANON_KEY     (safe for frontend)
#   4. Settings → Database → Connection string → URI   -> SUPABASE_DB_URL
#
# ⚠️ SUPABASE_SERVICE_KEY has FULL database access (bypasses RLS).
#    It must ONLY exist on the backend (HF Spaces secrets).
#    If you ever see it in frontend code, browser devtools, or Vercel,
#    rotate it IMMEDIATELY via Dashboard → Settings → API → Reset.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:[email protected]:6543/postgres


# ──────────────────────────────────────────────────────────────────────────
# PII hashing salt (required)
# ──────────────────────────────────────────────────────────────────────────
# 32-byte random string used to hash IPs and User-Agents before storing
# them in the database. Without a consistent salt you cannot correlate
# scans across requests, so DO NOT rotate this casually — rotation
# invalidates all historical correlations.
#
# Generate once and paste here:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Treat this with the same care as SUPABASE_SERVICE_KEY. If it leaks,
# attackers can reverse-hash any known IP into your audit log entries.
PII_HASH_SALT=


# ──────────────────────────────────────────────────────────────────────────
# Consent / ToS version (required)
# ──────────────────────────────────────────────────────────────────────────
# When you update the Terms of Service or scanning consent wording, bump
# this version. Audit log rows are stamped with the version in force at
# the time of consent, so future-you can prove which wording the user
# accepted if there's ever a legal challenge.
#
# v2 = added Pro plan sections 11–14 (paid plans, auto-renewal, refunds,
# fair use) + Lemon Squeezy as sub-processor in privacy policy.
CONSENT_VERSION=2026-04-10-v2


# ──────────────────────────────────────────────────────────────────────────
# Scan behavior (optional — defaults in code are sensible)
# ──────────────────────────────────────────────────────────────────────────
# Overall scan deadline in seconds. Default 180 (3 min).
# SCAN_DEADLINE_SECONDS=180

# Rate limit: max scans per IP per window (default 5 per 30 min)
# RATE_LIMIT_MAX=5
# RATE_LIMIT_WINDOW_SECONDS=1800

# Rate limit: max distinct target domains per IP per 24h without
# verification (default 3). Catches attackers scanning many different
# sites from one IP.
# RATE_LIMIT_DISTINCT_TARGETS=3


# ──────────────────────────────────────────────────────────────────────────
# Backup / Restore (required only for scripts/restore_backup.py)
# ──────────────────────────────────────────────────────────────────────────
# Automated daily backups run inside Supabase (edge function + pg_cron +
# Cloudflare R2). The production secrets live in Supabase Vault and are
# NOT needed in this .env file — DO NOT put them here.
#
# However, if you ever need to run `scripts/restore_backup.py` from a
# developer machine (list, inspect, or restore a backup), that script
# reads the same R2 credentials + encryption key from this file.
#
# Get the values from your password manager (encryption key) and the
# Cloudflare R2 dashboard (R2 credentials). Leave blank if you never
# plan to run the restore script — normal operation doesn't need them.
#
# ⚠️ BACKUP_ENCRYPTION_KEY is the SINGLE key without which ALL backups
#    are permanently unrecoverable. Store it in multiple secure places
#    (password manager + physical paper in a safe).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=security-scanner-backups
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
BACKUP_ENCRYPTION_KEY=


# ──────────────────────────────────────────────────────────────────────────
# Lemon Squeezy (Pro plan subscriptions)
# ──────────────────────────────────────────────────────────────────────────
# Payment processing for the Pro plan goes through Lemon Squeezy as
# Merchant of Record. Without these env vars the /api/status endpoint
# reports pro_available=false and the pricing page shows 'Coming Soon'
# buttons — that's the intended soft-launch state. Set these only on
# the day Lemon Squeezy approves the store, then factory-reboot the
# HF Space to flip the frontend into live mode.
#
# Where to find each value in the Lemon Squeezy dashboard:
#
#   API key:
#     Settings → API → "Create API key" → copy the lmn_sk_... token
#     Scope: All scopes. This is used by the backend for customer
#     portal URL generation (optional in V1) and future license key
#     verification against the Lemon Squeezy API.
#
#   Webhook signing secret:
#     Settings → Webhooks → your webhook → "Signing secret".
#     Our /webhooks/lemon endpoint verifies this with HMAC-SHA256
#     on every incoming event. Without it, we return 401 to any
#     caller claiming to be Lemon Squeezy.
#
#   Store ID:
#     URL of the store dashboard: app.lemonsqueezy.com/settings/stores/<ID>
#
#   Product ID + Variant IDs:
#     Open the product page in the dashboard; the ID is in the URL.
#     Each variant (monthly, yearly) has its own numeric ID visible
#     in the variants list.
#
#   Buy URLs:
#     Each variant exposes a "Share" button that gives you a
#     checkout URL like https://<store>.lemonsqueezy.com/buy/<uuid>
#     The frontend redirects users to these URLs when they click
#     "Start trial" on /pricing.
#
# ⚠️ LEMON_API_KEY + LEMON_WEBHOOK_SECRET are BACKEND SECRETS.
#    Put them in HF Space Secrets (encrypted), NOT Variables.
#    The ID-only env vars below are NOT secret and can go in
#    HF Space Variables alongside non-sensitive config.
LEMON_API_KEY=
LEMON_WEBHOOK_SECRET=
LEMON_STORE_ID=
LEMON_PRODUCT_ID=
LEMON_VARIANT_MONTHLY=
LEMON_VARIANT_YEARLY=
LEMON_BUY_URL_MONTHLY=
LEMON_BUY_URL_YEARLY=


# ──────────────────────────────────────────────────────────────────────────
# Local development only — DO NOT set on production
# ──────────────────────────────────────────────────────────────────────────
# DEBUG=false
# DEV_BYPASS_VERIFICATION=false   # set to true to skip ownership checks locally
